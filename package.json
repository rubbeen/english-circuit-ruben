{
  "name": "english-circuit-ruben",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run --exclude tests/firestore.rules.test.ts --exclude tests/e2e/** --exclude tests/responsive/** --exclude tests/offline/**",
    "test:unit": "vitest run src/**/*.test.ts",
    "test:components": "vitest run src/**/*.test.tsx",
    "test:e2e": "playwright test tests/e2e",
    "test:responsive": "playwright test tests/responsive",
    "test:offline": "playwright test tests/offline",
    "test:firestore-rules": "vitest run tests/firestore.rules.test.ts",
    "validate:content": "tsx scripts/validate-content.ts",
    "analyze:bundle": "node scripts/analyze-bundle.mjs",
    "guard:project": "node scripts/guards.mjs project",
    "guard:firebase": "node scripts/guards.mjs firebase",
    "guard:security": "node scripts/guards.mjs security",
    "guard:release": "node scripts/guards.mjs release",
    "cap:sync": "npm run build && cap sync android"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.2",
    "@capacitor/network": "^8.0.1",
    "firebase": "^12.16.0",
    "idb": "^8.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "firebase-tools": "^15.23.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
